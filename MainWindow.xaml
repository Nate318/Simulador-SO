<Window x:Class="SimuladorSO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SO Enterprise Simulator - Final Inspector" 
        WindowState="Maximized" 
        Background="#0F0F0F" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="15,8" Margin="2,0" Background="#222222" BorderBrush="#333" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#003366"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1A1A1A"/>
            <Setter Property="AlternatingRowBackground" Value="#222222"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="32"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7.5*"/>
            <ColumnDefinition Width="2.5*"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Background="Transparent" BorderThickness="0" Margin="10">

            <TabItem Header="⚙️ Sistema y Config">
                <Grid Margin="20">
                    <StackPanel MaxWidth="450" HorizontalAlignment="Left">
                        <TextBlock Text="Configuración del Hardware Simulado" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="Núcleos de CPU (Cores):" Foreground="#AAA" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtConfigCpus" Text="4" Background="#2D2D30" Foreground="White" Padding="8" BorderThickness="0"/>
                        <TextBlock Text="Límite: 1 a 16 núcleos" Foreground="#555" FontSize="11" Margin="0,2,0,10"/>

                        <TextBlock Text="Hilos por Núcleo (Threads):" Foreground="#AAA" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtConfigThreads" Text="2" Background="#2D2D30" Foreground="White" Padding="8" BorderThickness="0"/>
                        <TextBlock Text="Límite: 1 a 8 hilos" Foreground="#555" FontSize="11" Margin="0,2,0,10"/>

                        <TextBlock Text="Memoria RAM Total (MB):" Foreground="#AAA" Margin="0,10,0,5"/>
                        <TextBox x:Name="TxtConfigRam" Text="4096" Background="#2D2D30" Foreground="White" Padding="8" BorderThickness="0"/>
                        <TextBlock Text="Límite: 512 MB a 32768 MB" Foreground="#555" FontSize="11" Margin="0,2,0,20"/>

                        <Button Content="APLICAR Y REINICIAR SISTEMA" Background="#E91E63" Foreground="White" FontWeight="Bold" Padding="15" BorderThickness="0" Cursor="Hand" Click="BtnApplyConfig_Click"/>
                        <TextBlock x:Name="LblConfigStatus" Text="Advertencia: Aplicar cambios borrará los procesos actuales." Foreground="#FF9800" Margin="0,10,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="🖥️ CPUs y Procesos">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ItemsControl x:Name="CpuGrid" Grid.Row="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="6" Margin="5" Padding="15" BorderBrush="{Binding BorderColor}" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="#007ACC" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding ProcessData}" Foreground="White" TextWrapping="Wrap" MinHeight="40" FontSize="13" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Thermals}" Foreground="{Binding TempColor}" FontWeight="Bold" FontSize="11" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding FanSpeed}" Foreground="#AAAAAA" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Margin="5,5,5,5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Monitor de Ciclo de Vida (5 Estados)" Foreground="#FF9800" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="2">
                                        <TextBlock Text="1. NEW" Foreground="#AAAAAA" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <ItemsControl x:Name="ListStateNew">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2D2D30" BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="5" Margin="2">
                                                        <TextBlock Text="{Binding}" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="2">
                                        <TextBlock Text="2. READY" Foreground="#00BCD4" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <ItemsControl x:Name="ListStateReady">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2D2D30" BorderBrush="#00BCD4" BorderThickness="1" CornerRadius="4" Padding="5" Margin="2">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="2">
                                        <TextBlock Text="3. RUNNING" Foreground="#4CAF50" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <ItemsControl x:Name="ListStateRunning">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2D2D30" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="4" Padding="5" Margin="2">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="2">
                                        <TextBlock Text="4. WAITING" Foreground="#FF9800" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <ItemsControl x:Name="ListStateWaiting">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2D2D30" BorderBrush="#FF9800" BorderThickness="1" CornerRadius="4" Padding="5" Margin="2">
                                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Margin="2">
                                        <TextBlock Text="5. TERMINATED" Foreground="#F44336" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <ItemsControl x:Name="ListStateTerminated">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2D2D30" BorderBrush="#F44336" BorderThickness="1" CornerRadius="4" Padding="5" Margin="2">
                                                        <TextBlock Text="{Binding}" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center" TextDecorations="Strikethrough"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="GridProcesos" Grid.Row="2" Margin="5,10,5,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="45"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="110"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding State}" Width="85"/>
                            <DataGridTextColumn Header="Q(MLFQ)" Binding="{Binding MlfqQueueLevel}" Width="65"/>
                            <DataGridTextColumn Header="Mem MB" Binding="{Binding SizeMB}" Width="70"/>
                            <DataGridTextColumn Header="Razon Bloqueo" Binding="{Binding InterruptReason}" Width="150"/>
                            <DataGridTemplateColumn Header="Barra de Ejecución" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercentage, Mode=OneWay}" Height="16" Foreground="#007ACC" Background="#2D2D30" BorderThickness="0"/>
                                            <TextBlock Text="{Binding ProgressPercentage, Mode=OneWay, StringFormat={}{0}%}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="🧠 Gestión de Memoria">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Monitor de RAM Física (Páginas Rojas = Kernel R/O)" Foreground="#007ACC" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="#1E1E1E" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                            <Canvas x:Name="MemoryCanvas" Height="60" Background="Transparent" MouseMove="MemoryCanvas_MouseMove" MouseLeave="ClearMemoryInfo"/>
                        </Border>

                        <TextBlock Text="Archivo de Paginación SWAP (Disco Duro)" Foreground="#FF9800" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="#1E1E1E" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                            <Canvas x:Name="SwapCanvas" Height="30" Background="Transparent" MouseMove="SwapCanvas_MouseMove" MouseLeave="ClearMemoryInfo"/>
                        </Border>

                        <TextBlock Text="Translation Lookaside Buffer (Caché TLB Central)" Foreground="#4CAF50" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="GridTLB" Height="200" AutoGenerateColumns="True"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Métricas OOM y MMU" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                            <TextBlock x:Name="LblThrashing" Text="ESTADO: NORMAL" Foreground="#4CAF50" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                            <TextBlock x:Name="LblMmuStats" Text="Analizando..." Foreground="#E0E0E0" LineHeight="25" FontSize="14"/>

                            <Button Content="🚨 Inyectar Fuga (Llenar RAM)" Background="#E91E63" Foreground="White" Padding="10" Click="BtnLlenarRam_Click" BorderThickness="0" Margin="0,20,0,20" Cursor="Hand"/>

                            <Border Background="#1A2A3A" CornerRadius="6" Padding="15" BorderBrush="#00BCD4" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🔍 Inspector de Memoria (Hover)" Foreground="#00BCD4" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="LblHoverInfo" Text="Pase el cursor sobre la RAM o SWAP a la izquierda para ver los detalles aquí..." Foreground="#E0E0E0" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="💽 I/O Queues">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="6" Margin="5" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Controlador de Disco / SSD" Foreground="#FF9800" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox x:Name="ListDisk" Height="600" Background="#121212" Foreground="White" BorderThickness="0" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="6" Margin="5" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Controlador de Red TCP/IP" Foreground="#00BCD4" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox x:Name="ListNet" Height="600" Background="#121212" Foreground="White" BorderThickness="0" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="6" Margin="5" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Gestión Kernel / Paginación" Foreground="#E91E63" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox x:Name="ListSys" Height="600" Background="#121212" Foreground="White" BorderThickness="0" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📊 Benchmark Comparativo">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="7*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="6" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Configurar Prueba" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                            <TextBlock Text="Cantidad (N Procesos):" Foreground="#AAA" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtNumN" Text="50" Background="#2D2D30" Foreground="White" Padding="8" Margin="0,0,0,20" BorderThickness="0"/>
                            <Button x:Name="BtnRunBenchmark" Content="Ejecutar Benchmark" Background="#007ACC" Foreground="White" Padding="15" FontWeight="Bold" Click="BtnRunBenchmark_Click" BorderThickness="0" Cursor="Hand"/>

                            <TextBlock x:Name="LblBenchmarkStatus" Text="Esperando inicio..." Foreground="#AAAAAA" Margin="0,20,0,5" FontWeight="Bold"/>
                            <ProgressBar x:Name="BenchmarkProgress" Height="15" Minimum="0" Maximum="100" Value="0" Foreground="#00BCD4" Background="#2D2D30" BorderThickness="0"/>
                            <ListBox x:Name="ListBenchmarkLive" Height="300" Background="#121212" Foreground="#4CAF50" FontFamily="Consolas" BorderThickness="0" Margin="0,10,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="6" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Resultados Científicos de la Comparativa" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                            <DataGrid x:Name="GridBenchmark" AutoGenerateColumns="True" FontSize="14" RowHeight="40"/>

                            <Border Background="#121212" CornerRadius="6" Padding="15" Margin="0,20,0,0" BorderBrush="#333" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🏆 Análisis de Eficiencia del Kernel" Foreground="#FF9800" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="LblFastest" Text="⚡ Más Rápido (Ticks Totales): Esperando..." Foreground="#A7F3D0" Margin="0,3" FontSize="13"/>
                                            <TextBlock x:Name="LblSlowest" Text="🐢 Más Lento (Ticks Totales): Esperando..." Foreground="#FCA5A5" Margin="0,3" FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="LblPredictable" Text="🎯 Más Predecible (Varianza Baja): Esperando..." Foreground="#93C5FD" Margin="0,3" FontSize="13"/>
                                            <TextBlock x:Name="LblBestTurnaround" Text="⏱️ Mejor Turnaround Promedio: Esperando..." Foreground="#FDBA74" Margin="0,3" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock x:Name="LblVeredicto" Text="Veredicto: Ejecuta una prueba para ver el análisis." Foreground="#E0E0E0" FontStyle="Italic" Margin="0,15,0,0" TextWrapping="Wrap" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Column="1" Background="#1A1A1A" BorderBrush="#333" BorderThickness="1,0,0,0" Padding="15">
            <StackPanel>

                <TextBlock Text="Paleta Global" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <Button x:Name="BtnToggle" Content="▶ INICIAR KERNEL" Background="#007ACC" Foreground="White" Padding="15" FontSize="14" FontWeight="Bold" Click="BtnToggle_Click" BorderThickness="0" Cursor="Hand" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Velocidad Reloj:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="SldVelocidad" Width="150" Minimum="10" Maximum="500" Value="100" IsDirectionReversed="True" VerticalAlignment="Center" ValueChanged="SldVelocidad_ValueChanged"/>
                </StackPanel>

                <Border Background="#222" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="1. Inyección de Procesos" Foreground="#AAAAAA" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtMem" Grid.Column="0" Text="128" Background="#2D2D30" Foreground="White" CaretBrush="White" Padding="6" Margin="0,0,5,0" ToolTip="Memoria MB"/>
                            <TextBox x:Name="TxtTicks" Grid.Column="1" Text="80" Background="#2D2D30" Foreground="White" CaretBrush="White" Padding="6" Margin="0,0,5,0" ToolTip="Ticks Burst"/>
                            <TextBox x:Name="TxtPrio" Grid.Column="2" Text="5" Background="#2D2D30" Foreground="White" CaretBrush="White" Padding="6" ToolTip="Prioridad"/>
                        </Grid>
                        <Button Content="+ Crear Proceso" Background="#4CAF50" Foreground="White" Padding="10" Click="BtnCrear_Click" BorderThickness="0" Margin="0,0,0,10" Cursor="Hand"/>
                        <Button x:Name="BtnAuto" Content="Auto-Spawn: OFF" Background="#607D8B" Foreground="White" Padding="10" Click="BtnAuto_Click" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <Border Background="#222" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="2. Syscalls IPC y Gestión" Foreground="#AAAAAA" FontWeight="Bold" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="TxtActionPID" Width="60" Text="4" Background="#2D2D30" Foreground="White" CaretBrush="White" Padding="6" BorderThickness="0" Margin="0,0,10,0" ToolTip="PID Destino"/>
                            <Button Content="Kill" Background="#F44336" Foreground="White" Padding="10,6" Click="BtnKill_Click" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0" Width="60"/>
                            <Button Content="Fork" Background="#FF9800" Foreground="White" Padding="10,6" Click="BtnFork_Click" BorderThickness="0" Cursor="Hand" Width="60"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="TxtIpcFrom" Width="40" Text="4" Background="#2D2D30" Foreground="White" CaretBrush="White" Padding="6" BorderThickness="0" Margin="0,0,5,0" ToolTip="PID Origen"/>
                            <TextBox x:Name="TxtIpcTo" Width="40" Text="5" Background="#2D2D30" Foreground="White" CaretBrush="White" Padding="6" BorderThickness="0" Margin="0,0,10,0" ToolTip="PID Destino"/>
                            <Button Content="Shared Mem" Background="#009688" Foreground="White" Padding="10,6" Click="BtnIpc_Click" BorderThickness="0" Cursor="Hand" Width="105"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#222" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="3. Algoritmo Planificador" Foreground="#AAAAAA" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ComboBox x:Name="CmbPolitica" Padding="8" SelectionChanged="CmbPolitica_SelectionChanged">
                            <ComboBoxItem Content="MLFQ (Multilevel Feedback Queue)" IsSelected="True"/>
                            <ComboBoxItem Content="FCFS (First Come First Serve)"/>
                            <ComboBoxItem Content="SJF (Shortest Job First)"/>
                            <ComboBoxItem Content="Round Robin"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Quantum (RR):" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtQuantum" Text="4" Width="40" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="4" TextAlignment="Center"/>
                            <Button Content="Aplicar" Background="#007ACC" Foreground="White" Padding="10,4" Margin="10,0,0,0" Click="BtnApplyQuantum_Click" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Traza del Kernel (Log)" Foreground="#007ACC" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <ScrollViewer x:Name="ConsoleScroll" Background="Black" Padding="5" Height="150" Margin="0,0,0,0">
